# 复制此文件为 secret.yaml，填入真实值后 kubectl apply
# 注意：secret.yaml 已加入 .gitignore，不会被提交
apiVersion: v1
kind: Secret
metadata:
  name: k8sgate-db-secret
  namespace: k8sgate-system
type: Opaque
stringData:
  host: "mysql-master.example.com"
  username: "k8sgate"
  password: "YOUR_DB_PASSWORD"

---
apiVersion: v1
kind: Secret
metadata:
  name: k8sgate-jwt-secret
  namespace: k8sgate-system
type: Opaque
stringData:
  secret: "CHANGE_ME_TO_A_RANDOM_STRING"
